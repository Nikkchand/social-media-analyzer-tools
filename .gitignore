# Environment and configuration files (critical for security)
.env*
!.env.example  # Allow the example file if it's a template without secrets

# Firebase-specific (to avoid committing service accounts or project configs with secrets)
.firebase/
.firebaserc  # Often contains project IDs, but ignore to be safe; use .firebaserc.example instead

# Additional build and cache files (common in Vite/Firebase projects)
.vite/
.cache/
.parcel-cache/
*.tsbuildinfo

# OS-specific files (additional Windows/macOS entries)
Thumbs.db
*.swp
*.swo

